{
  "name": "adniamey2000",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node --watch --env-file .env src/index.js",
    "start": "node --env-file .env src/index.js",
    "seed": "node --env-file .env src/db/seed.js",
    "build:css": "csso public/css/style.css --output public/css/style.min.css",
    "build:js": "terser public/js/i18n.js -o public/js/i18n.min.js && terser public/js/api.js -o public/js/api.min.js && terser public/js/script.js -o public/js/script.min.js && terser public/js/dynamic.js -o public/js/dynamic.min.js",
    "build": "npm run build:css && npm run build:js"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "csso-cli": "^4.0.2",
    "terser": "^5.47.1"
  }
}
